{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"['.nuxt','.output'].forEach((d)=>require('fs').rmSync(d,{ recursive: true, force: true }))\"",
    "clean-build": "npm run clean && nuxt build",
    "build": "nuxt build",
    "dev": "nuxi dev --no-fork --port 4000 --host 0.0.0.0",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "node scripts/generate-remixicon-slim.mjs && nuxt prepare"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@nuxt/fonts": "^0.14.0",
    "@pinia/nuxt": "^0.7.0",
    "browser-image-compression": "^2.0.2",
    "firebase": "^10.14.1",
    "libphonenumber-js": "^1.13.3",
    "nuxt": "^3.14.159",
    "nuxt-gtag": "^3.0.2",
    "nuxt-vuefire": "^1.0.4",
    "pinia": "^2.2.6",
    "remixicon": "^4.9.1",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "playwright": "^1.58.2",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "0.24.0"
  }
}
