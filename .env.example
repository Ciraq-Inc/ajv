# API Configuration
API_BASE_URL=http://localhost:3009/api

# Google Analytics
GTAG_ID=G-XXXXXXXXXX

# Paystack Configuration
# Get your keys from https://dashboard.paystack.com/settings/developer
# For testing, use test keys (pk_test_xxx and sk_test_xxx)
# For production, use live keys (pk_live_xxx and sk_live_xxx)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Access Control (optional frontend gate component)
ACCESS_CONTROL_USERNAME=admin
ACCESS_CONTROL_PASSWORD=change_me
